generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  admin
  organizer
  customer
  vendor
  guest
}

enum EventType {
  wedding
  corporate
  birthday
  conference
  concert
  other
}

enum EventStatus {
  draft
  planning
  confirmed
  ongoing
  completed
  cancelled
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(60)
  label     String   @db.VarChar(100)
  color     String   @default("default") @db.VarChar(30)
  icon      String?  @db.VarChar(60)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("service_categories")
}

enum PriceType {
  fixed
  per_person
  hourly
  custom
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum OrderStatus {
  draft
  quoted
  placed
  in_progress
  completed
  cancelled
}

enum ActivityStatus {
  not_started
  in_progress
  completed
  blocked
}

enum RsvpStatus {
  pending
  accepted
  declined
  maybe
}

enum MediaType {
  photo
  video
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique
  password  String
  role      UserRole @default(organizer)
  phone     String?
  avatar    String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  events        Event[]   @relation("OrganizerEvents")
  vendorProfile Vendor?
  bookings      Booking[] @relation("OrganizerBookings")
  verifiedVendors Vendor[] @relation("VendorVerifiedBy")
  customerOrders EventOrder[] @relation("CustomerOrders")
  organizerOrders EventOrder[] @relation("OrganizerOrders")
  activityUpdates EventActivity[] @relation("ActivityUpdatedBy")
  reviews       Review[]
  media         Media[]
  appNotifications AppNotification[]

  @@map("users")
}

model AppNotification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(64)
  title     String   @db.VarChar(200)
  body      String   @db.Text
  read      Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt(sort: Desc)])
  @@map("app_notifications")
}

model AiRecommendationSnapshot {
  id         Int      @id @default(autoincrement())
  eventId    Int      @map("event_id")
  userId     Int?     @map("user_id")
  category   String?  @db.VarChar(64)
  vendorId   Int      @map("vendor_id")
  fitScore   Int      @map("fit_score")
  confidence String?  @db.VarChar(16)
  reasons    Json     @default("[]")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([eventId, category, createdAt])
  @@index([vendorId, createdAt])
  @@map("ai_recommendation_snapshots")
}

model Event {
  id          Int         @id @default(autoincrement())
  title       String      @db.VarChar(200)
  slug        String      @unique
  type        EventType
  description String?     @db.Text
  date        DateTime
  endDate     DateTime?   @map("end_date")
  venue       String
  address     String?
  city        String?
  state       String?
  lat         Float?
  lng         Float?
  budget      Decimal     @default(0) @db.Decimal(12, 2)
  guestCount  Int         @default(0) @map("guest_count")
  organizerId Int         @map("organizer_id")
  status      EventStatus @default(draft)
  coverImage  String?     @map("cover_image")
  isPublic    Boolean     @default(false) @map("is_public")
  netlifySiteId String?   @map("netlify_site_id") @db.VarChar(120)
  netlifySiteUrl String?  @map("netlify_site_url") @db.VarChar(500)
  netlifyPublishedAt DateTime? @map("netlify_published_at")
  qrDestinationType String @default("auto") @map("qr_destination_type") @db.VarChar(20)
  sectorCustomizations Json @default("{}") @map("sector_customizations")
  customerPreferences Json  @default("{}") @map("customer_preferences")
  timeline    Json        @default("[]")
  tasks       Json        @default("[]")
  inviteDripEnabled      Boolean   @default(false) @map("invite_drip_enabled")
  inviteDripIntervalDays Int       @default(2) @map("invite_drip_interval_days")
  inviteDripLastSentAt   DateTime? @map("invite_drip_last_sent_at")
  inviteDripVideoUrl     String?   @map("invite_drip_video_url") @db.VarChar(500)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  organizer User      @relation("OrganizerEvents", fields: [organizerId], references: [id])
  bookings  Booking[]
  guests    Guest[]
  orders    EventOrder[]
  activities EventActivity[]
  budgetRec Budget?
  reviews   Review[]
  media     Media[]
  inviteJobs InviteJob[]

  @@index([organizerId, date])
  @@index([status])
  @@map("events")
}

model Vendor {
  id            Int            @id @default(autoincrement())
  userId        Int            @unique @map("user_id")
  businessName  String         @map("business_name")
  category      String         @db.VarChar(60)
  description   String?        @db.Text
  basePrice     Decimal        @default(0) @db.Decimal(12, 2) @map("base_price")
  currency      String         @default("INR") @db.VarChar(10)
  priceType     PriceType      @default(fixed) @map("price_type")
  packages      Json           @default("[]") // Service packages/tiers offered
  portfolio     Json           @default("[]")
  availability  Json           @default("[]")
  city          String?
  state         String?
  contactPhone  String?        @map("contact_phone")
  contactEmail  String?        @map("contact_email")
  website       String?
  socialLinks   Json           @default("{}") @map("social_links")
  averageRating Decimal        @default(0) @db.Decimal(2, 1) @map("average_rating")
  totalReviews  Int            @default(0) @map("total_reviews")
  isVerified    Boolean        @default(false) @map("is_verified")
  verificationStatus VerificationStatus @default(pending) @map("verification_status")
  verifiedAt    DateTime?      @map("verified_at")
  verifiedByAdminId Int?       @map("verified_by_admin_id")
  verificationNotes String?    @db.Text @map("verification_notes")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id])
  verifiedBy User?   @relation("VendorVerifiedBy", fields: [verifiedByAdminId], references: [id])
  bookings Booking[]
  reviews  Review[]
  packageCatalog VendorPackage[]
  testimonials VendorTestimonial[]
  orderItems EventOrderItem[]
  activities EventActivity[]

  @@index([category])
  @@index([city])
  @@index([averageRating])
  @@map("vendors")
}

model VendorPackage {
  id              Int            @id @default(autoincrement())
  vendorId        Int            @map("vendor_id")
  title           String         @db.VarChar(160)
  description     String         @db.Text
  category        String         @db.VarChar(60)
  tier            String         @db.VarChar(80)
  basePrice       Decimal        @db.Decimal(12, 2) @map("base_price")
  currency        String         @default("INR") @db.VarChar(10)
  unitLabel       String?        @map("unit_label")
  estimationRules Json           @default("{}") @map("estimation_rules")
  deliverables    Json           @default("[]")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  orderItems      EventOrderItem[]

  @@index([vendorId, category])
  @@map("vendor_packages")
}

model VendorTestimonial {
  id          Int      @id @default(autoincrement())
  vendorId    Int      @map("vendor_id")
  clientName  String   @map("client_name")
  content     String   @db.Text
  rating      Int      @default(5)
  source      String?  @db.VarChar(120)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vendor      Vendor   @relation(fields: [vendorId], references: [id])

  @@index([vendorId])
  @@map("vendor_testimonials")
}

model EventOrder {
  id          Int         @id @default(autoincrement())
  eventId     Int         @map("event_id")
  customerId  Int         @map("customer_id")
  organizerId Int         @map("organizer_id")
  status      OrderStatus @default(draft)
  quotedTotal Decimal     @default(0) @db.Decimal(12, 2) @map("quoted_total")
  finalTotal  Decimal?    @db.Decimal(12, 2) @map("final_total")
  notes       String?     @db.Text
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  event       Event       @relation(fields: [eventId], references: [id])
  customer    User        @relation("CustomerOrders", fields: [customerId], references: [id])
  organizer   User        @relation("OrganizerOrders", fields: [organizerId], references: [id])
  items       EventOrderItem[]
  activities  EventActivity[]

  @@index([customerId, status])
  @@index([organizerId, status])
  @@map("event_orders")
}

model EventOrderItem {
  id              Int            @id @default(autoincrement())
  orderId         Int            @map("order_id")
  vendorId        Int            @map("vendor_id")
  packageId       Int            @map("package_id")
  category        String         @db.VarChar(60)
  packageTitle    String         @map("package_title")
  criteriaSnapshot Json          @default("{}") @map("criteria_snapshot")
  quotedPrice     Decimal        @db.Decimal(12, 2) @map("quoted_price")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  order           EventOrder     @relation(fields: [orderId], references: [id])
  vendor          Vendor         @relation(fields: [vendorId], references: [id])
  package         VendorPackage  @relation(fields: [packageId], references: [id])

  @@index([orderId, category])
  @@map("event_order_items")
}

model EventActivity {
  id               Int            @id @default(autoincrement())
  orderId          Int            @map("order_id")
  eventId          Int            @map("event_id")
  vendorId         Int?           @map("vendor_id")
  category         String         @db.VarChar(60)
  title            String         @db.VarChar(180)
  description      String?        @db.Text
  status           ActivityStatus @default(not_started)
  progressPercent  Int            @default(0) @map("progress_percent")
  spendPlanned     Decimal        @default(0) @db.Decimal(12, 2) @map("spend_planned")
  spendActual      Decimal        @default(0) @db.Decimal(12, 2) @map("spend_actual")
  updatedById      Int?           @map("updated_by_id")
  updatedByUserAt  DateTime?      @map("updated_by_user_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  order            EventOrder     @relation(fields: [orderId], references: [id])
  event            Event          @relation(fields: [eventId], references: [id])
  vendor           Vendor?        @relation(fields: [vendorId], references: [id])
  updatedBy        User?          @relation("ActivityUpdatedBy", fields: [updatedById], references: [id])

  @@index([eventId, category])
  @@index([orderId, status])
  @@map("event_activities")
}

model Booking {
  id          Int           @id @default(autoincrement())
  eventId     Int           @map("event_id")
  vendorId    Int           @map("vendor_id")
  organizerId Int           @map("organizer_id")
  status      BookingStatus @default(pending)
  price       Decimal       @db.Decimal(12, 2)
  notes       String?       @db.Text
  serviceDate DateTime      @map("service_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  event     Event  @relation(fields: [eventId], references: [id])
  vendor    Vendor @relation(fields: [vendorId], references: [id])
  organizer User   @relation("OrganizerBookings", fields: [organizerId], references: [id])

  @@unique([eventId, vendorId])
  @@map("bookings")
}

model Guest {
  id                 Int        @id @default(autoincrement())
  eventId            Int        @map("event_id")
  name               String
  email              String?
  phone              String?
  rsvpStatus         RsvpStatus @default(pending) @map("rsvp_status")
  plusOnes           Int        @default(0) @map("plus_ones")
  dietaryPreferences String?    @map("dietary_preferences")
  tableAssignment    String?    @map("table_assignment")
  qrCode             String?    @db.Text @map("qr_code")
  checkedIn          Boolean    @default(false) @map("checked_in")
  checkedInAt        DateTime?  @map("checked_in_at")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  @@index([eventId])
  @@index([eventId, email])
  @@map("guests")
}

model Budget {
  id          Int      @id @default(autoincrement())
  eventId     Int      @unique @map("event_id")
  totalBudget Decimal  @db.Decimal(12, 2) @map("total_budget")
  guestCount  Int      @map("guest_count")
  allocations Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id])

  @@map("budgets")
}

model Review {
  id        Int      @id @default(autoincrement())
  vendorId  Int      @map("vendor_id")
  userId    Int      @map("user_id")
  eventId   Int?     @map("event_id")
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  event  Event? @relation(fields: [eventId], references: [id])

  @@unique([vendorId, userId])
  @@map("reviews")
}

model Media {
  id         Int       @id @default(autoincrement())
  eventId    Int       @map("event_id")
  uploadedBy Int?      @map("uploaded_by")
  guestName  String?   @map("guest_name")
  url        String
  publicId   String?   @map("public_id")
  type       MediaType @default(photo)
  caption    String?   @db.VarChar(500)
  isApproved Boolean   @default(false) @map("is_approved")
  isFlagged  Boolean   @default(false) @map("is_flagged")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  event    Event @relation(fields: [eventId], references: [id])
  uploader User? @relation(fields: [uploadedBy], references: [id])

  @@index([eventId])
  @@map("media")
}

// ── Invite Video System ──────────────────────────────────────────────

enum InviteJobStatus {
  pending
  processing
  completed
  failed
}

model InviteJob {
  id            Int             @id @default(autoincrement())
  eventId       Int             @map("event_id")
  status        InviteJobStatus @default(pending)
  templateKey   String?         @map("template_key") @db.VarChar(500)   // R2 folder e.g. templates/{id}
  musicKey      String?         @map("music_key") @db.VarChar(500)
  imageKeys     Json            @default("[]") @map("image_keys")       // array of R2 keys
  voiceTemplate String?         @map("voice_template") @db.VarChar(500) // e.g. "Dear {name}, please join us for ..."
  voiceLang     String          @default("en") @map("voice_lang") @db.VarChar(10)  // TTS language code
  totalGuests   Int             @default(0) @map("total_guests")
  processed     Int             @default(0)
  failed        Int             @default(0)
  error         String?         @db.Text
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  event       Event           @relation(fields: [eventId], references: [id])
  guestVideos InviteGuestVideo[]

  @@index([eventId, status])
  @@map("invite_jobs")
}

model InviteGuestVideo {
  id          Int             @id @default(autoincrement())
  jobId       Int             @map("job_id")
  guestName   String          @map("guest_name") @db.VarChar(200)
  phone       String          @db.VarChar(20)
  status      InviteJobStatus @default(pending)
  videoKey    String?         @map("video_key") @db.VarChar(500)
  videoUrl    String?         @map("video_url") @db.VarChar(500)
  messageSent Boolean         @default(false) @map("message_sent")
  retries     Int             @default(0)
  error       String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  job         InviteJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@map("invite_guest_videos")
}
