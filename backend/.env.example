PORT=5000
# Local: postgresql://postgres:postgres@localhost:5432/eventos
# Supabase (direct): URL-encode special characters in the password (e.g. , → %2C  $ → %24  @ → %40)
# Example shape (use your project host and encoded password):
# DATABASE_URL="postgresql://postgres:ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventos
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/eventos
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
NODE_ENV=development

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@eventos.com

CLIENT_URL=http://localhost:3000
# Optional: extra allowed browser origins (comma-separated), e.g. another frontend URL
# CORS_ORIGINS=
# Allow any https://*.vercel.app origin (needed for Vercel preview deployments)
# CORS_ALLOW_VERCEL=true

# Contact intelligence and invite automation
CONTACT_DEFAULT_COUNTRY_CODE=+91
# Optional JSON override. Keep empty to use built-in multilingual defaults.
CONTACT_RELATION_DICTIONARY_JSON=
CONTACT_RELATIVE_RELATIONS_JSON=

# WhatsApp provider configuration (replace with production values)
WHATSAPP_PROVIDER=mock
WHATSAPP_DRY_RUN=true
WHATSAPP_FROM_NUMBER=
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_TEMPLATE_PREFIX=eventos_

# Public invite extensions
INVITE_GIFTING_ENABLED=true
INVITE_GIFT_UPI_ID=
INVITE_GIFT_PAYEE_NAME=Event Family
INVITE_GIFT_NOTE=Blessings for your special day
INVITE_REMOTE_BLESSINGS_ENABLED=true
INVITE_REMOTE_BLESSINGS_AUTO_APPROVE=false
INVITE_AI_COLLAGE_ENABLED=true
INVITE_AI_COLLAGE_PROVIDER=mock
INVITE_AI_COLLAGE_DRY_RUN=true
INVITE_AI_COLLAGE_MIN_PHOTOS=2
INVITE_AI_COLLAGE_DEFAULT_STYLE=traditional
INVITE_AI_COLLAGE_ALLOWED_STYLES=traditional,modern,cinematic
