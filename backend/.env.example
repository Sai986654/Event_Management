PORT=5000
# Local: postgresql://postgres:postgres@localhost:5432/eventos
# Supabase (direct): URL-encode special characters in the password (e.g. , → %2C  $ → %24  @ → %40)
# Example shape (use your project host and encoded password):
# DATABASE_URL="postgresql://postgres:ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require"
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eventos
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/eventos
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d
NODE_ENV=development

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
FROM_EMAIL=noreply@eventos.com

CLIENT_URL=http://localhost:3000

# Optional: LLM for contact segmentation + correlate (Google CSV + Invite Intelligence). If unset, rule-based only.
# Use OpenAI and/or Groq. If only GROQ_API_KEY is set, Groq is used. If both keys exist, OpenAI wins unless:
# CONTACT_AI_PROVIDER=groq
OPENAI_API_KEY=
# Groq (OpenAI-compatible): https://console.groq.com/keys — default model llama-3.3-70b-versatile when CONTACT_AI_MODEL is empty
GROQ_API_KEY=
# CONTACT_AI_PROVIDER=openai
# CONTACT_AI_PROVIDER=groq
# Empty = provider default (OpenAI: gpt-4o-mini, Groq: llama-3.3-70b-versatile). Set explicitly if you use one key for both providers.
CONTACT_AI_MODEL=
# Smaller = more reliable JSON for large CSVs (default 12 contacts per OpenAI request)
# CONTACT_AI_BATCH_SIZE=12
# Max completion tokens per batch (default 8192)
# CONTACT_AI_MAX_TOKENS=8192
# Optional cap for multi-select “Correlate selected” (OpenAI) responses.
# CONTACT_AI_CORRELATE_MAX_TOKENS=4096
CONTACT_AI_ENABLED=true
# Verbose OpenAI request logging (sample payload)
# CONTACT_AI_DEBUG=true
# Optional JSON override for rule-based Telugu labels (see contactIntelligenceConfig defaults)
# CONTACT_TELUGU_LABELS_JSON=
# Optional: extra allowed browser origins (comma-separated)
# CORS_ORIGINS=
# Only CLIENT_URL + CORS_ORIGINS (no automatic *.vercel.app previews)
# CORS_STRICT=true
# Disable default *.vercel.app allowlist (use with CORS_STRICT)
# CORS_ALLOW_VERCEL=false

# Contact intelligence and invite automation
CONTACT_DEFAULT_COUNTRY_CODE=+91
# Optional JSON override. Keep empty to use built-in multilingual defaults.
CONTACT_RELATION_DICTIONARY_JSON=
CONTACT_RELATIVE_RELATIONS_JSON=
# Optional JSON arrays merged with built-ins: last name token = employer ("Lakshmi Accenture") or profession ("Ravi Plumber")
# CONTACT_EMPLOYER_SUFFIXES_JSON=["mycompany","startupx"]
# CONTACT_PROFESSION_SUFFIXES_JSON=["gardener","pandit"]

# WhatsApp — default is mock (logs only, no real sends). "Eligible" in the UI = has phone number.
# Production: Meta Cloud API (https://developers.facebook.com/docs/whatsapp/cloud-api/get-started) or Twilio.
# Then set WHATSAPP_DRY_RUN=false and implement HTTP in backend/services/notificationService.js sendWhatsApp().
WHATSAPP_PROVIDER=mock
WHATSAPP_DRY_RUN=true
WHATSAPP_FROM_NUMBER=
WHATSAPP_API_BASE_URL=
WHATSAPP_API_KEY=
WHATSAPP_TEMPLATE_PREFIX=eventos_

# Public invite extensions
INVITE_GIFTING_ENABLED=true
INVITE_GIFT_UPI_ID=
INVITE_GIFT_PAYEE_NAME=Event Family
INVITE_GIFT_NOTE=Blessings for your special day
INVITE_REMOTE_BLESSINGS_ENABLED=true
INVITE_REMOTE_BLESSINGS_AUTO_APPROVE=false
INVITE_AI_COLLAGE_ENABLED=true
INVITE_AI_COLLAGE_PROVIDER=mock
INVITE_AI_COLLAGE_DRY_RUN=true
INVITE_AI_COLLAGE_MIN_PHOTOS=2
INVITE_AI_COLLAGE_DEFAULT_STYLE=traditional
INVITE_AI_COLLAGE_ALLOWED_STYLES=traditional,modern,cinematic
