{
  "expo": {
    "name": "Vedika 360",
    "slug": "vedika360-mobile",
    "version": "1.0.0",
    "scheme": "vedika360",
    "orientation": "portrait",
    "icon": "./assets/icon.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#0a4f7a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vedika360.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.jpeg",
        "backgroundColor": "#0a4f7a"
      },
      "package": "com.vedika360.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vedika 360 to access your photos to upload blessing images for events.",
          "cameraPermission": "Allow Vedika 360 to use the camera to capture blessing photos for events."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "d51c79e4-6880-4c1f-8e93-22928854bd11"
      }
    },
    "owner": "sai986654"
  }
}
