{
  "expo": {
    "name": "Vedika 360",
    "slug": "vedika360-mobile",
    "version": "1.0.0",
    "scheme": "vedika360",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#667eea"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vedika360.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#667eea"
      },
      "package": "com.vedika360.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vedika 360 to access your photos to upload blessing images for events.",
          "cameraPermission": "Allow Vedika 360 to use the camera to capture blessing photos for events."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c72f450a-d76e-4d32-a59b-0a6dbe60b68c"
      }
    }
  }
}
