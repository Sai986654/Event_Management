# API = Render (or local) — must end with /api. Do not point at another Vercel frontend URL.
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_SOCKET_URL=http://localhost:5000

# Production: set in Vercel → Environment Variables (Production + Preview), then redeploy
# REACT_APP_API_URL=https://YOUR-SERVICE.onrender.com/api
# REACT_APP_SOCKET_URL=https://YOUR-SERVICE.onrender.com
